# Copia questo file in .env e personalizza le password prima di avviare i container
DB_PASSWORD=cambia_questa_password_forte
DB_ROOT_PASSWORD=cambia_anche_questa_root_password
SITE_URL=https://myband.it

# Configurazione SMTP per le notifiche email dei messaggi di contatto (opzionale:
# se lasci SMTP_HOST vuoto, le notifiche sono semplicemente disattivate)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
SMTP_FROM=
SMTP_FROM_NAME=myband.it
